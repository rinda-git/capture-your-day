    <%# ── バリデーションエラー ── %>
    <!--<% if resource.errors.any? %>
      <div role="alert" class="alert alert-error mb-4">
        <p class="font-bold mb-1">入力内容を確認してください</p>
        <ul>
          <% resource.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %> -->
    
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>  
  <% if resource.errors.any? %>
  <div role="alert" class="alert alert-error mb-4">
  <%= render "devise/shared/error_messages", resource: resource %>
  </div>
  <% end %>

  <div class="mb-4">
    <p><%= f.label :name, class: "block text-sm font-medium text-ink-sub mb-1" %></p>
    <p><%= f.text_field :name,
           autofocus: true,
           autocomplete: "name",
           class:"input input-bordered w-full bg-base-200 focus:bg-base-100 rounded-xl" %></p>
  </div>

  <div class="mb-4">
    <p><%= f.label :email %></p>
    <p><%= f.email_field :email, 
           autofocus: true, 
           autocomplete: "email", 
           class: "input input-bordered w-full bg-base-200 focus:bg-base-100 rounded-xl" %></p>
  </div>

  <div class="mb-4">
    <%= f.label :password %>
    <% if @minimum_password_length %>
        <%=  t('devise.shared.minimum_password_length', count: @minimum_password_length) %>
    <% end %>
    <p><%= f.password_field :password, 
           autocomplete: "new-password",
           class: "input input-bordered w-full bg-base-200 focus:bg-base-100 rounded-xl" %></p>
  </div>

  <div class="mb-4">
    <p><%= f.label :password_confirmation %></p>
    <p><%= f.password_field :password_confirmation, 
           autocomplete: "new-password",
           class: "input input-bordered w-full bg-base-200 focus:bg-base-100 rounded-xl" %></p>
  </div>

  <div class="actions">
    <%= f.submit t('devise.registrations.new.sign_up'), class: "btn btn-primary w-full rounded-xl" %>
  </div>
<% end %>
   <%# ── 区切り ── %>
    <div class="divider text-sm text-base-content/50">または</div>
    <%# ── ログインリンク ── %>
    <p class="text-center text-sm text-base-content/60 mb-2">すでにアカウントをお持ちの方</p>
    <%= link_to t('devise.registrations.new.to_log_in'), new_user_session_path,
        class: "btn btn-outline w-full rounded-xl" %>
