<%= content_for(:title, t('.title', default: APP_NAME)) %>
<main class="flex-grow px-4 sm:px-6 md:px-10">
<div class="max-w-3xl mx-auto md:px-0 pt-6">
  <h1 class="font-bold font-title text-3xl md;text-4xl text-center font-cream-500 mb-6">
  My Journal
  </h1>

    <!-- <div class="actions mb-4">
  <%= link_to "日記を書く", new_journal_path(posted_date:Date.current), class:"btn btn-primary" %>
  </div> -->

    <%# 日記一覧をループ %>
    <% @journals.each do |journal| %>
      <%#　1件ずつ枠で囲む  %>
      <div class="text-right">
      <%= button_to "削除",
          journal_path(journal),
          method: :delete,
          form: {data: {turbo_confirm:"このジャーナルを削除しますか？"}},
          class: "text-sm text-center hover:opacity-70"
       %>
      </div>

      <%= link_to journal_path(journal), class:"block border border-cream-300 bg-white rounded-lg px-4 py-3" do %>
      
      <p class="font-bold text-cream-500 mb-3">
      <%= journal.posted_date.strftime("%Y/%m/%d") %>
      </p>
      
      <p class="mb-3 line-clamp-2">
          <%= journal.corrected_body %>
      </p>
      <% end %>
      

    <% end %>

    
  </div>
</div>
</main>